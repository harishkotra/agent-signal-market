# ── Publisher credentials (for publishing signals + receiving x402 payments) ──
# From https://web3.okx.com/build/dev-portal
PUBLISHER_OKX_API_KEY=
PUBLISHER_OKX_SECRET_KEY=
PUBLISHER_OKX_PASSPHRASE=
PUBLISHER_OKX_PROJECT_ID=
PUBLISHER_WALLET_ADDRESS=       # Agentic Wallet EVM address for receiving payments
SIGNAL_CHAIN=501                # Chain to monitor for signals (501=Solana)
PUBLISHER_PORT=3001

# ── Consumer credentials (for paying x402 + executing trades) ──
# Note: x402 signing uses PUBLISHER_OKX_SECRET_KEY (shared secret between publisher & consumer)
# X402_MODE=simulated  (simulated HMAC, works out of the box)
# X402_MODE=real       (uses OnChainOS Agentic Wallet - requires CLI setup)
# X402_MODE=permit     (EIP-3009 permit structure, verifiable but not claimable without wallet)
CONSUMER_OKX_API_KEY=
CONSUMER_OKX_SECRET_KEY=
CONSUMER_OKX_PASSPHRASE=
CONSUMER_OKX_PROJECT_ID=
CONSUMER_WALLET_ADDRESS=        # Agentic Wallet EVM address for signing x402

# ── Consumer strategy ──
STRATEGY_MIN_CONFIDENCE=70
STRATEGY_MAX_MCAP=5000000
STRATEGY_MIN_LIQUIDITY=100000
STRATEGY_BUY_AMOUNT_USD=10
STRATEGY_SLIPPAGE=0.5
STRATEGY_CHAIN=501

# ── Ports ──
CONSUMER_PORT=3002               # Consumer API server port

# ── Publisher URL ──
PUBLISHER_URL=http://localhost:3001
POLL_INTERVAL_MS=15000          # How often the consumer polls (ms)
MAX_TRADES_PER_RUN=3            # Max auto-trades before stopping
